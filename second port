<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Aakash K S — Implementation Engineer</title>

  <!-- Updated Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet"/>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-main: #f2f4f3;
      --bg-card: #ffffff;
      --text-main: #1c1c1c;
      --text-muted: #5f6368;
      --accent: #2d5a27;
      --accent-light: #e4efe6;
      --border: #d6d9d6;

      --font-display: 'DM Serif Display', serif;
      --font-body: 'Inter', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--bg-main);
      color: var(--text-main);
      font-size: 16px;
      line-height: 1.75;
      font-weight: 400;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 4rem;
      background: rgba(242, 244, 243, 0.85);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--text-main);
      text-decoration: none;
    }

    .nav-links { display: flex; gap: 2rem; list-style: none; }

    .nav-links a {
      text-decoration: none;
      font-size: 0.875rem;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    .nav-links a:hover { color: var(--text-main); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center;
      padding: 8rem 4rem 4rem;
      position: relative;
    }

    .hero-inner { max-width: 760px; }

    .hero-tag {
      font-size: 0.75rem;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--accent-light);
      padding: 0.3rem 0.9rem;
      border-radius: 2rem;
      margin-bottom: 1.5rem;
      display: inline-block;
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 7vw, 5rem);
      margin-bottom: 1.5rem;
    }

    .hero h1 em { color: var(--accent); }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .btn {
      padding: 0.8rem 1.6rem;
      text-decoration: none;
      border-radius: 4px;
      font-size: 0.9rem;
    }

    .btn-primary {
      background: var(--text-main);
      color: white;
    }

    .btn-outline {
      border: 1px solid var(--border);
      color: var(--text-main);
    }

    /* SECTIONS */
    section {
      padding: 6rem 4rem;
      border-top: 1px solid var(--border);
    }

    section:nth-child(even) {
      background: #eef1ef;
    }

    .section-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    /* ABOUT */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 4rem;
    }

    .about-text {
      color: var(--text-muted);
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 2rem;
    }

    .stat {
      border-left: 2px solid var(--accent);
      padding-left: 1rem;
    }

    /* SKILLS */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .skill-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 1.5rem;
      border-radius: 8px;
    }

    .skill-items {
      color: var(--text-muted);
    }

    /* EXPERIENCE */
    .exp-item {
      padding: 2rem 0;
      border-bottom: 1px solid var(--border);
    }

    .exp-desc {
      color: var(--text-muted);
    }

    /* PROJECTS */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .project-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
    }

    .project-body {
      padding: 1.5rem;
    }

    .project-desc {
      color: var(--text-muted);
    }

    /* BLOG */
    .blog-excerpt {
      color: var(--text-muted);
    }

    /* CONTACT */
    .contact-row {
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 1rem;
      border-radius: 8px;
      text-decoration: none;
      color: var(--text-main);
      display: flex;
      justify-content: space-between;
    }

    footer {
      padding: 2rem 4rem;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      nav, section, footer {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      .about-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

<nav>
  <a href="#" class="nav-logo">Aakash K S</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#blog">Blog</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-inner">
    <span class="hero-tag">Available for opportunities</span>
    <h1>Aakash K S<br><em>Implementation</em><br>Engineer</h1>
    <p class="hero-sub">Deploying systems that work in real environments.</p>
    <a href="#projects" class="btn btn-primary">View Projects</a>
  </div>
</section>

<section id="about">
  <div class="about-grid">
    <div>
      <div class="section-label">About</div>
      <h2 class="section-title">Execution over theory</h2>
    </div>
    <div class="about-text">
      <p>Implementation Engineer focused on production-grade deployments.</p>
    </div>
  </div>
</section>

<section id="skills">
  <div class="section-label">Skills</div>
  <h2 class="section-title">Stack</h2>
  <div class="skills-grid">
    <div class="skill-card">
      <div class="skill-items">Docker · Kubernetes · AWS · CI/CD</div>
    </div>
  </div>
</section>

<section id="experience">
  <div class="section-label">Experience</div>
  <h2 class="section-title">Work</h2>
  <div class="exp-item">
    <p class="exp-desc">Reduced deployment time using automation.</p>
  </div>
</section>

<section id="projects">
  <div class="section-label">Projects</div>
  <h2 class="section-title">Builds</h2>
  <div class="projects-grid">
    <div class="project-card">
      <div class="project-body">
        <p class="project-desc">Automation pipeline.</p>
      </div>
    </div>
  </div>
</section>

<section id="contact">
  <div class="section-label">Contact</div>
  <h2 class="section-title">Reach</h2>
  <a class="contact-row">Email</a>
</section>

<footer>
  <span>© 2025 Aakash</span>
</footer>

</body>
</html>
